---
import type { PageBlock } from "../../lib/content-types";
import HeroBlock from "../blocks/HeroBlock.astro";
import CalloutBlock from "../blocks/CalloutBlock.astro";
import AccordionBlock from "../blocks/AccordionBlock.astro";
import NumberedAccordionBlock from "../blocks/NumberedAccordionBlock.astro";
import ContactsBlock from "../blocks/ContactsBlock.astro";
import HeadingBlock from "../blocks/HeadingBlock.astro";
import IntroBlock from "../blocks/IntroBlock.astro";
import FeaturedDesignsBlock from "../blocks/FeaturedDesignsBlock.astro";
import AllDesignsBlock from "../blocks/AllDesignsBlock.astro";
import DesignDetailsBlock from "../blocks/DesignDetailsBlock.astro";

const { block } = Astro.props as { block: PageBlock };
---

{
    block.type === "hero_block" && <HeroBlock block={block} />
}

{
    block.type === "callout_block" && <CalloutBlock block={block} />
}

{
    block.type === "accordion_block" && <AccordionBlock block={block} />
}

{
    block.type === "numbered_accordion_block" && <NumberedAccordionBlock block={block} />
}

{
    block.type === "contacts_block" && <ContactsBlock block={block} />
}

{
    block.type === "heading_block" && <HeadingBlock block={block} />
}

{
    block.type === "intro_block" && <IntroBlock block={block} />
}

{
    block.type === "featured_designs_block" && <FeaturedDesignsBlock block={block} />
}

{
    block.type === "all_designs_block" && <AllDesignsBlock block={block} />
}

{
    block.type === "design_details_block" && <DesignDetailsBlock block={block} />
}
