---
import { type PageModel, type PageBlock, DesignPageModel, DesignsPageModel } from '../../lib/models'
import HeroBlock from '../blocks/HeroBlock.astro'
import CalloutBlock from '../blocks/CalloutBlock.astro'
import AccordionBlock from '../blocks/AccordionBlock.astro'
import NumberedAccordionBlock from '../blocks/NumberedAccordionBlock.astro'
import ContactsBlock from '../blocks/ContactsBlock.astro'
import HeadingBlock from '../blocks/HeadingBlock.astro'
import IntroBlock from '../blocks/IntroBlock.astro'
import SectionDesignsBlock from '../blocks/SectionDesignsBlock.astro'
import DesignDetailsBlock from '../blocks/DesignDetailsBlock.astro'

interface Props {
  block: PageBlock
  page: PageModel
}

const { block, page } = Astro.props
---

{
  (() => {
    switch (block.type) {
      case 'hero_block':
        return <HeroBlock block={block} />
      case 'callout_block':
        return <CalloutBlock block={block} />
      case 'accordion_block':
        return <AccordionBlock block={block} />
      case 'numbered_accordion_block':
        return <NumberedAccordionBlock block={block} />
      case 'contacts_block':
        return <ContactsBlock block={block} />
      case 'heading_block':
        return <HeadingBlock block={block} />
      case 'intro_block':
        return <IntroBlock block={block} />
      case 'section_designs_block':
        return <SectionDesignsBlock block={block} page={page as DesignsPageModel} />
      case 'design_details_block':
        return <DesignDetailsBlock block={block} page={page as DesignPageModel} />
    }
  })()
}
