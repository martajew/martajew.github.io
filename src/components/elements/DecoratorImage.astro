---
import { getAllSettings } from '../../lib/content'

const { layout } = await getAllSettings()
const { class: className } = Astro.props
---

{
  layout.decoratorImage && (
    <span
      class:list={['block shrink-0 h-11', className]}
      style={`
        aspect-ratio: ${layout.decoratorImage.width} / ${layout.decoratorImage.height};
        -webkit-mask: url(${layout.decoratorImage.src}) center / contain no-repeat;
        mask: url(${layout.decoratorImage.src}) center / contain no-repeat;
      `}
      aria-hidden="true"
    />
  )
}
