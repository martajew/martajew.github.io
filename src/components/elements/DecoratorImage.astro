---
import { getSettings } from '../../lib/content'
import { optimizeImage } from '../../lib/images'

interface Props {
  class?: string
}

const { layout } = await getSettings()
const decoratorImage = await optimizeImage(layout.decoratorImage, { maxWidth: 128 })
const { class: className } = Astro.props
---

{
  decoratorImage && (
    <span
      class:list={['block shrink-0 h-11', className]}
      style={`
        aspect-ratio: ${decoratorImage.width} / ${decoratorImage.height};
        -webkit-mask: url(${decoratorImage.src}) center / contain no-repeat;
        mask: url(${decoratorImage.src}) center / contain no-repeat;
      `}
      aria-hidden="true"
    />
  )
}
