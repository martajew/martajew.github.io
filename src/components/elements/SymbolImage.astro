---
import { Image } from 'astro:assets'
import { getSiteSettings } from '../../lib/content'

const settings = await getSiteSettings()
const variants = {
  light: settings.layout.symbolLightImage,
  dark: settings.layout.symbolDarkImage,
}

interface Props {
  variant: keyof typeof variants
}

const { variant } = Astro.props
const symbolImage = variants[variant]
---

{symbolImage && <Image src={symbolImage} alt="Symbol" loading="eager" />}
