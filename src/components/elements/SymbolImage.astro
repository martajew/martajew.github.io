---
import { getAllSettings } from '../../lib/content'

const { layout } = await getAllSettings()
const { class: className } = Astro.props
---

{
  layout.symbolImage && (
    <span
      class:list={['block shrink-0 h-5 self-center', className]}
      style={`
        aspect-ratio: ${layout.symbolImage.width} / ${layout.symbolImage.height};
        -webkit-mask: url(${layout.symbolImage.src}) center / contain no-repeat;
        mask: url(${layout.symbolImage.src}) center / contain no-repeat;
      `}
      aria-hidden="true"
    />
  )
}
