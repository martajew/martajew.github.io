---
import { Image } from 'astro:assets'
import type { ImageMetadata, ImageOutputFormat, ImageQuality } from 'astro'
import { IMAGE_PRESET, getResponsiveSizes, getResponsiveWidths } from '../../lib/images'

interface Props extends Record<string, unknown> {
  src?: ImageMetadata | undefined
  alt?: string | undefined
  class?: string
  loading?: 'eager' | 'lazy'
  width?: number
  height?: number
  widths?: number[]
  sizes?: string
  format?: ImageOutputFormat
  quality?: ImageQuality
}

const {
  src,
  alt = '',
  widths,
  sizes,
  format = IMAGE_PRESET.format,
  quality = IMAGE_PRESET.quality,
  ...props
} = Astro.props

const responsiveWidths = widths ?? getResponsiveWidths(src)
const responsiveSizes = sizes ?? getResponsiveSizes(src)
---

{
  src && (
    <Image
      src={src}
      alt={alt}
      widths={responsiveWidths}
      sizes={responsiveSizes}
      format={format}
      quality={quality}
      {...props}
    />
  )
}
