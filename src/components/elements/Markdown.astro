---
import type { HTMLAttributes } from 'astro/types'
import '../../styles/markdown.css'
import { marked } from 'marked'

interface Props extends HTMLAttributes<'div'> {
  content: string | undefined
  variant?: 'xsm' | 'sm' | 'md' | 'lg' | 'xl'
}

const { content, variant = 'sm', class: className, ...rest } = Astro.props

// common styling for all markdown variants
const baseStyle = 'markdown-content prose max-w-none prose-a:hover:text-base-700 prose-headings:font-sans'

const variantStyle = {
  xsm: 'text-12 font-mono',
  sm: 'text-16/8 font-mono',
  md: 'text-20 font-mono font-semibold uppercase text-base-700',
  lg: 'text-32/8 font-sans',
  xl: 'text-40/10 font-sans',
}

const html = await marked.parse(content ?? '', { breaks: true, gfm: true })
---

<div class:list={[baseStyle, variantStyle[variant], className]} set:html={html} {...rest} />
