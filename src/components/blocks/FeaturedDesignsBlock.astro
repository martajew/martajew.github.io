---
import type {PageBlocksMap} from "../../lib/content-types";
import Container from "../elements/Container.astro";
import Heading from "../elements/Heading.astro";
import Design from "../elements/Design.astro";
import Link from "../elements/Link.astro";
import {getFeaturedDesigns} from "../../lib/content";

const {block} = Astro.props as { block: PageBlocksMap["featured_designs_block"] };
const featuredDesigns = await getFeaturedDesigns();
---

<Container variant={"lg"} class="items-center">
    <Heading tagName="h2" tagSize="h2" class="text-center">{block.heading}</Heading>
    <Container class="grid lg:grid-cols-2 grid-cols-1 gap-16">
      {
        featuredDesigns.map((design) => (
                <Design
                        collection={design.collection}
                        slug={design.data.slug}
                        featuredImage={design.data.featuredImage}
                        title={design.data.title}
                        client={design.data.client}
                        category={design.data.category}
                />
        ))
      }
    </Container>
    <Link variant={"button"} href={block.link}>{block.button}</Link>
</Container>
