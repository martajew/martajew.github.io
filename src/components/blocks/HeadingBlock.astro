---
import type { PageBlocksMap } from '../../lib/models'
import Container from '../elements/Container.astro'
import Heading from '../elements/Heading.astro'

const block = Astro.props.block as PageBlocksMap['heading_block']
---

<Container variant={'xl'} class="text-center">
  <Heading tagName="h1" tagSize="h1">
    {block.title}
  </Heading>
</Container>
