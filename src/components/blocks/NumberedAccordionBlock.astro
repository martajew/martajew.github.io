---
import type { PageBlocksMap } from '../../lib/models'
import SectionPanelList from '../elements/SectionPanelList.astro'
import Dropdown from '../elements/Dropdown.astro'

interface Props {
  block: PageBlocksMap['numbered_accordion_block']
}

const { block } = Astro.props
---

<SectionPanelList heading={block.heading} , size={block.size}>
  {block.items.map((item, index) => <Dropdown title={`${index + 1}. ${item.title}`} text={item.text} />)}
</SectionPanelList>
