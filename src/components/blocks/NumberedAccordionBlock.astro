---
import type { PageBlocksMap } from '../../lib/content'
import SectionPanelList from '../elements/SectionPanelList.astro'
import Dropdown from '../elements/Dropdown.astro'

const block = Astro.props.block as PageBlocksMap['numbered_accordion_block']
---

<SectionPanelList heading={block.heading}>
  {
    block.items.map((item, index) => {
      const numberedTitle = `${index + 1}. ${item.title}`
      return <Dropdown title={numberedTitle} text={item.text} />
    })
  }
</SectionPanelList>
