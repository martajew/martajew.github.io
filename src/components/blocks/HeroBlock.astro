---
import type { HeroBlock } from "../../lib/content-types";
import Container from "../elements/Container.astro";
import RichText from "../elements/RichText.astro";
import Heading from "../elements/Heading.astro";
import ImageContainer from "../elements/ImageContainer.astro";
import Link from "../elements/Link.astro";

const { block } = Astro.props as { block: HeroBlock };
---

<Container variant={"xl"} class="flex flex-col gap-8 min-h-screen">
    <RichText variant={"xl"} class="text-base-900 lg:max-w-1/3 md:max-w-1/2 w-full" content={block.intro} />
    <Container class="flex md:flex-row flex-col gap-8">
        <Container class="md:flex-2 flex flex-col items-start gap-4">
            <Link variant={"button"} href={block.link}>{block.button}</Link>
            <Heading tagName="h1" tagSize="h1">{block.name}</Heading>
        </Container>
        <Container class="h-full md:h-[500px] flex-1">
            <ImageContainer src={block.image} alt={block.name} />
        </Container>
    </Container>
</Container>

