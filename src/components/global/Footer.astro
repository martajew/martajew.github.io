---
// components
import Container from "../elements/Container.astro";
import Heading from "../elements/Heading.astro";
import Text from "../elements/Text.astro";
import Link from "../elements/Link.astro";

// content
import { getCollection } from "astro:content";
const pages = await getCollection("pages");
const sitePage = pages.find((entry) => entry.data.template === "site");
if (!sitePage) {
    throw new Error("Missing or invalid pages/site.md entry.");
}
const navigation = sitePage.data.navLinks;
const footer = sitePage.data.footer;
---

<Container variant={'xl'} class="mt-32 pb-8">
    <div class="flex flex-col gap-10 md:flex-row">
        <div class="flex-1 md:text-left text-center">
            <Heading tagName="h3" tagSize="h4" class="text-base-900 mb-5">{footer.socialsHeading}</Heading>
            <ul>
                {
                    footer.socials.map((social) => (
                        <li><Link variant={'nav'} href={social.href}>{social.title}</Link></li>
                    ))
                }
            </ul>
        </div>
        <div class="flex-1 md:text-right text-center">
            <Heading tagName="h3" tagSize="h4" class="text-base-900 mb-5">{footer.navigationHeading}</Heading>
            <ul>
                {
                    navigation.map((navLink) => (
                        <li><Link variant={'nav'} href={navLink.href}>{navLink.title}</Link></li>
                    ))
                }
            </ul>
        </div>
    </div>
    <div class="flex flex-col text-center">
        <Text variant={'sm'} class="text-base-900">{footer.copyright}</Text>
        <Text variant={'sm'} class="text-base-900">
            {footer.creditsPrefix} <Link variant={'inline'} href={footer.builtWithHref}>{footer.builtWithLabel}</Link> by <Link variant={'inline'} href={footer.builtByHref}>{footer.builtByLabel}</Link>
        </Text>
    </div>
</Container>
