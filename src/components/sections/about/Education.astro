---
// components
import ResumeDropdown from "../../elements/ResumeDropdown.astro";
import SectionPanelList from "../../elements/SectionPanelList.astro";
import type { EducationContent } from "../../../lib/content-types";

const { content } = Astro.props as { content: EducationContent };
---

<SectionPanelList heading={content.heading}>
    {
        content.items.map((item) => (
            <ResumeDropdown title={item.title} place={item.place} period={item.period} text={item.text} />
        ))
    }
</SectionPanelList>
