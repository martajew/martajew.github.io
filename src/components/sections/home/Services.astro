---
// components
import Dropdown from "../../elements/Dropdown.astro";
import SectionPanelList from "../../elements/SectionPanelList.astro";
import type { ServicesContent } from "../../../lib/content-types";

const { content } = Astro.props as { content: ServicesContent };
---

<SectionPanelList heading={content.heading}>
    {
        content.items.map((service, index) => (
            <Dropdown title=`${index + 1}. ${service.title}` text={service.text} />  
        ))
    }
</SectionPanelList>
