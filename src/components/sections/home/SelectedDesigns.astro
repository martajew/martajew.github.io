---
// components
import Container from "../../elements/Container.astro";
import Heading from "../../elements/Heading.astro";
import Design from "../../elements/Design.astro";
import Link from "../../elements/Link.astro";

// content collections
import { getCollection } from "astro:content";
const designs = await getCollection("designs");
const featuredDesigns = designs.filter((design) => design.data.isFeatured === true);

interface SelectedDesignsContent {
    heading: string;
    buttonLabel: string;
    buttonHref: string;
}
const { content } = Astro.props as { content: SelectedDesignsContent };
---

<Container variant={'lg'} class="items-center">
    <Heading tagName="h2" tagSize="h2" class="text-center">
        {content.heading}
    </Heading>
    <Container class="grid lg:grid-cols-2 grid-cols-1 gap-16">
        {featuredDesigns.map((design) => (
            <Design 
                slug={design.data.slug}
                featuredImage={design.data.featuredImage}
                title={design.data.title}
                client={design.data.client}
                category={design.data.category}>
            </Design>
        ))
        }
    </Container>
    <Link variant={'button'} href={content.buttonHref}>{content.buttonLabel}</Link>
</Container>
