---
// components
import Dropdown from "../../elements/Dropdown.astro";
import SectionPanelList from "../../elements/SectionPanelList.astro";
import type { FaqContent } from "../../../lib/content-types";

const { content } = Astro.props as { content: FaqContent };
---

<SectionPanelList heading={content.heading}>
    {
        content.items.map((q, index) => (
            <Dropdown title=`${index + 1}. ${q.title}`  text={q.text} />
        ))
    }
</SectionPanelList>
