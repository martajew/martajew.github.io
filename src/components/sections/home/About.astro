---
// components
import Heading from "../../elements/Heading.astro";
import Text from "../../elements/Text.astro";
import Container from "../../elements/Container.astro";
import Link from "../../elements/Link.astro";
import ImageContainer from "../../elements/ImageContainer.astro";
import type { HomeAboutContent } from "../../../lib/content-types";
const { content } = Astro.props as { content: HomeAboutContent };
---

<Container variant={'xl'}>
    <Heading tagName="h2" tagSize="h2" class="text-center">{content.heading}</Heading>
    <div class="flex lg:flex-row lg:gap-16 gap-10 flex-col">
        <div class="flex flex-col items-start gap-6 lg:pt-6 text-base-900 lg:flex-1">
            <Text variant={'xl'}>{content.lead}</Text>
            <Text variant={'sm'}>{content.bodyOne}</Text>
            <Text variant={'sm'}>{content.bodyTwo}</Text>
            <Link variant={'button'} href={content.buttonHref}>{content.buttonLabel}</Link>
        </div>
        <div class="w-full lg:h-[500px] h-auto lg:flex-1">
            <ImageContainer src={content.image} alt={content.imageAlt} />
        </div>
    </div>
</Container>
