---
// components
import Container from "../../elements/Container.astro";
import Design from "../../elements/Design.astro";

// content collections
import { getCollection } from "astro:content";
const designs = await getCollection("designs");
---

<Container variant={'lg'}>
    <Container class="grid lg:grid-cols-2 grid-cols-1 gap-24">
        {designs.map((design) => (
            <Design 
                slug={design.data.slug}
                featuredImage={design.data.featuredImage}
                title={design.data.title}
                client={design.data.client}
                category={design.data.category}>
            </Design>
        ))
        }
    </Container>
</Container>
