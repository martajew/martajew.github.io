---
import Layout from '../layouts/Layout.astro'
import PageBlocks from '../components/pages/PageBlocks.astro'
import type { PageModel } from '../lib/models'

export { getStaticPaths } from '../lib/content'

interface Props {
  page: PageModel
}

const { page } = Astro.props
---

<Layout title={page.getTitle()}>
  <PageBlocks page={page} />
</Layout>
