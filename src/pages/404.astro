---
import Layout from "../layouts/Layout.astro";
import PageBlocks from "../components/pages/PageBlocks.astro";
import { getPageBySlug } from "../lib/content";

const notFoundPage = await getPageBySlug("not-found");
---

<Layout title={notFoundPage.data.title}>
    <PageBlocks blocks={notFoundPage.data.blocks} />
</Layout>
