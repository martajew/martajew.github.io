---
import Layout from '../layouts/Layout.astro'
import { getSettings } from '../lib/content.ts'
import { PageModel } from '../lib/models'
import IntroBlock from '../components/blocks/IntroBlock.astro'

const { navigation } = await getSettings()
const page = await PageModel.fromReference(navigation.notFoundPage)

if (page?.getSanitizedPermalink()) {
  const permalink = page.getNormalizedPermalink()
  if (permalink === undefined) return Astro.rewrite('/')
  return Astro.rewrite(`/${permalink}`)
}
---

<Layout title="Page Not Found">
  <IntroBlock
    block={{
      heading: 'Page Not Found',
      lead: 'Oops! It seems the page you are trying to access does not exist!',
      button: 'Go back to the homepage',
      link: '/',
    }}
  />
</Layout>
