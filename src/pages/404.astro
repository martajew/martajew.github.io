---
// layout
import Layout from "../layouts/Layout.astro";

// components
import Container from "../components/elements/Container.astro";
import Heading from "../components/elements/Heading.astro";
import Text from "../components/elements/Text.astro";
import Link from "../components/elements/Link.astro";

// content
import { getPageDataByTemplate } from "../lib/content";
const notFoundPage = await getPageDataByTemplate("not-found");
---

<Layout title={notFoundPage.pageTitle}>
    <Container variant={'xl'} class="text-center flex items-center">
        <div class="flex flex-col gap-4">
            <Heading tagName="h1" tagSize="h1">{notFoundPage.heading}</Heading>
            <Text variant={'xl'} class="text-base-900">{notFoundPage.message}</Text>    
        </div>
        
        <Link variant={'button'} href={notFoundPage.buttonHref}>{notFoundPage.buttonLabel}</Link>
    </Container>
</Layout>
