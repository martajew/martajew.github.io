---
import type {GetStaticPaths} from "astro";
import Layout from "../layouts/Layout.astro";
import PageBlocks from "../components/pages/PageBlocks.astro";
import {getPagePaths, getDesignPaths, getDesignBySlug} from "../lib/content";

export const getStaticPaths = (async () => {
  const pages = await getPagePaths();
  const designs = await getDesignPaths();
  return [...pages, ...designs];

}) satisfies GetStaticPaths;

const {slug} = Astro.params;
const {page, title} = Astro.props;

if (page.data.blocks.some((block) => block.type === "design_details_block")) {
  if (!(await getDesignBySlug(slug))) return Astro.redirect("/404.html"); // rewrite causes infinite loop
}
---

<Layout title={title}>
    <PageBlocks blocks={page.data.blocks}/>
</Layout>
