---
import type {GetStaticPaths} from "astro";
import Layout from "../layouts/Layout.astro";
import PageBlocks from "../components/pages/PageBlocks.astro";
import {getAllPages, getPublishedDesigns, sanitizeSlug} from "../lib/content";
import type {PageEntry} from "../lib/content-types.ts";

export const getStaticPaths = (async () => {
  const pages = await getAllPages();
  const pageRoutes = pages.map((entry) => {
    const slug = sanitizeSlug(entry.data.slug);
    return {params: {slug}, props: {entry}};
  });
  const designs = await getPublishedDesigns();
  const designRoutes = designs.map((design) => {
    const slug = `${design.collection}/${sanitizeSlug(design.data.slug)}`;
    const entry = design as unknown as PageEntry;
    entry.data["title"] = `Design - ${design.data.title}`;
    entry.data["blocks"] = [{type: "design_details_block", design}];
    return {params: {slug}, props: {entry}};
  });
  return [...pageRoutes, ...designRoutes];

}) satisfies GetStaticPaths;

const entry = Astro.props.entry as PageEntry;
---

<Layout title={entry.data.title}>
    <PageBlocks blocks={entry.data.blocks}/>
</Layout>
