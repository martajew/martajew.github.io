---
import type {GetStaticPaths} from "astro";
import Layout from "../layouts/Layout.astro";
import PageBlocks from "../components/pages/PageBlocks.astro";
import {getPagePaths, getDesignPaths} from "../lib/content";
import type {PageEntry} from "../lib/content-types.ts";

export const getStaticPaths = (async () => {
  const pages = await getPagePaths();
  const designs = await getDesignPaths();
  return [...pages, ...designs];

}) satisfies GetStaticPaths;

const entry = Astro.props.entry as PageEntry;
---

<Layout title={entry.data.title}>
    <PageBlocks blocks={entry.data.blocks}/>
</Layout>
