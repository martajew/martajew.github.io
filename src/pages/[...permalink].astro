---
import type { GetStaticPaths } from 'astro'
import Layout from '../layouts/Layout.astro'
import PageBlocks from '../components/pages/PageBlocks.astro'
import { getPagePaths, getDesignPaths } from '../lib/content'

export const getStaticPaths = (async () => {
  const pages = await getPagePaths()
  const designs = await getDesignPaths()
  return [...pages, ...designs]
}) satisfies GetStaticPaths

const { title, page } = Astro.props
---

<Layout title={title}>
  <PageBlocks blocks={page.entry.data.blocks} />
</Layout>
