---
// layout 
import Layout from "../layouts/Layout.astro"

// components
import Intro from "../components/sections/contact/Intro.astro"
import ContactDetails from "../components/sections/contact/ContactDetails.astro"

// content
import { getPageDataByTemplate } from "../lib/content";
const contactPage = await getPageDataByTemplate("contact");
---

<Layout title={contactPage.pageTitle}>
    <Intro content={contactPage.intro} />
    <ContactDetails items={contactPage.contactDetails.items} />
</Layout>
