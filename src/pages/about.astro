---
// layout
import Layout from "../layouts/Layout.astro";

// components
import Intro from "../components/sections/about/Intro.astro";
import Experience from "../components/sections/about/Experience.astro";
import Education from "../components/sections/about/Education.astro";

// content
import { getPageDataByTemplate } from "../lib/content";
const aboutPage = await getPageDataByTemplate("about");
---

<Layout title={aboutPage.pageTitle}>
    <Intro content={aboutPage.intro} />
    <Experience content={aboutPage.experience} />
    <Education content={aboutPage.education} />
</Layout>
