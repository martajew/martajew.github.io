---
// layout
import Layout from '../layouts/Layout.astro';

// components
import Hero from '../components/sections/home/Hero.astro';
import SelectedDesigns from '../components/sections/home/SelectedDesigns.astro';
import Services from '../components/sections/home/Services.astro';
import About from '../components/sections/home/About.astro';
import Faq from '../components/sections/home/Faq.astro';

// content
import { getPageDataByTemplate } from "../lib/content";
const homePage = await getPageDataByTemplate("home");
---

<Layout title={homePage.pageTitle}>
    <Hero content={homePage.hero} />
    <SelectedDesigns content={homePage.selectedDesigns} />
    <Services content={homePage.services} />
    <About content={homePage.aboutSection} />
    <Faq content={homePage.faq} />
</Layout>
