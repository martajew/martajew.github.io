---
// stylesheet
import '../styles/global.css'
import { getGoogleFontConfig } from '../lib/fonts'

// components
import BaseHead from '../components/global/BaseHead.astro'
import Wrapper from '../components/global/Wrapper.astro'
import NavBar from '../components/global/Navigation.astro'
import Footer from '../components/global/Footer.astro'
import { getAllSettings } from '../lib/content'

// props
const { title } = Astro.props
const { layout } = await getAllSettings()
const fonts = getGoogleFontConfig(layout)

const styleRules = [
  layout.backgroundImage ? `background-image: url(${layout.backgroundImage.src})` : undefined,
  fonts.sansVar ? `--font-sans: ${fonts.sansVar}` : undefined,
  fonts.monoVar ? `--font-mono: ${fonts.monoVar}` : undefined,
  layout.primaryColor ? `--color-base-900: ${layout.primaryColor}` : undefined,
  layout.secondaryColor ? `--color-base-700: ${layout.secondaryColor}` : undefined,
  layout.contrastColor ? `--color-base-100: ${layout.contrastColor}` : undefined,
]
const style = styleRules.filter(Boolean).join('; ')
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <BaseHead title={title} />
  <body style={style} class="bg-cover bg-center bg-no-repeat bg-fixed box-border">
    <!-- Background noise effect -->
    <div class="noise-[67,22,25] fixed inset-0 pointer-events-none"></div>
    <!-- Wrapper component to make sure all content on the website is above the noise filter background -->
    <Wrapper>
      <NavBar />
      <main class="flex flex-col xl:gap-48 lg:gap-40 gap-28">
        <slot />
      </main>
      <Footer />
    </Wrapper>
  </body>
</html>
